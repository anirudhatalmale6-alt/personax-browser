{
  "name": "boorat",
  "version": "1.5.0",
  "description": "Boorat Anti-Detect Browser",
  "main": "main.js",
  "author": "Boorat",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.boorat.antidetect",
    "productName": "BOORAT",
    "artifactName": "BooratSetup.${ext}",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "anirudhatalmale6-alt",
        "repo": "boorat-browser",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "shortcutName": "BOORAT",
      "menuCategory": true
    },
    "extraResources": [
      {
        "from": "../launcher-go/boorat-server.exe",
        "to": "boorat-server.exe"
      },
      {
        "from": "../launcher-go/builtin-extensions",
        "to": "builtin-extensions",
        "filter": ["**/*"]
      },
      {
        "from": "../launcher-go/PROXY.csv",
        "to": "PROXY.csv"
      }
    ]
  }
}
