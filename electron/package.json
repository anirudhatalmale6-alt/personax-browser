{
  "name": "personax",
  "version": "2.9.2",
  "description": "PersonaX Anti-Detect Browser",
  "main": "main.js",
  "author": "PersonaX",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.personax.antidetect",
    "productName": "PERSONAX",
    "artifactName": "PersonaXSetup.${ext}",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "anirudhatalmale6-alt",
        "repo": "personax-browser",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "../launcher-go/personax-server.exe",
          "to": "personax-server.exe"
        },
        {
          "from": "../launcher-go/builtin-extensions",
          "to": "builtin-extensions",
          "filter": ["**/*"]
        },
        {
          "from": "../launcher-go/PROXY.csv",
          "to": "PROXY.csv"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "icon.png",
      "category": "public.app-category.utilities",
      "artifactName": "PersonaXSetup-mac-${arch}.${ext}",
      "extraResources": [
        {
          "from": "../launcher-go/personax-server-${arch}",
          "to": "personax-server"
        },
        {
          "from": "../launcher-go/builtin-extensions",
          "to": "builtin-extensions",
          "filter": ["**/*"]
        },
        {
          "from": "../launcher-go/PROXY.csv",
          "to": "PROXY.csv"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "shortcutName": "PERSONAX",
      "menuCategory": true
    }
  }
}
